# Base URL Configuration
# In development, this can be inferred from the request (e.g., http://localhost:3000)
# In production, this MUST be set to your full domain
APP_URL=http://localhost:3000

# JWT Configuration
# Generate a secure secret with: openssl rand -base64 32
# REQUIRED - Application will not start without this
JWT_SECRET=

# Acquia Cloud API Configuration
# Get these from Acquia Cloud Platform
ACQUIA_API_KEY=
ACQUIA_API_SECRET=
NEXT_PUBLIC_ACQUIA_SUBSCRIPTION_UUID=

# Acquia Entitlements (Monthly limits)
NEXT_PUBLIC_ACQUIA_MONTHLY_VIEWS_ENTITLEMENT=
NEXT_PUBLIC_ACQUIA_MONTHLY_VISITS_ENTITLEMENT=

# Stanford SAML Configuration
# UAT (development): https://login-uat.stanford.edu/idp/profile/SAML2/Redirect/SSO
# Production: https://login.stanford.edu/idp/profile/SAML2/Redirect/SSO
SAML_ENTRY_POINT=https://login-uat.stanford.edu/idp/profile/SAML2/Redirect/SSO

# Stanford IdP Certificate (from Stanford IT)
# UAT and Production use different certificates
SAML_CERT="-----BEGIN CERTIFICATE-----
...
-----END CERTIFICATE-----"

# Your Service Provider Certificate
# Generate with: openssl req -x509 -newkey rsa:2048 -keyout saml-sp.key -out saml-sp.crt -days 3650 -nodes
SAML_SP_CERT="-----BEGIN CERTIFICATE-----
...
-----END CERTIFICATE-----"

# Your Service Provider Private Key
# KEEP THIS SECRET - Never commit to version control
SAML_SP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"
